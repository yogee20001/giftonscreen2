rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public uploads and reads for gift photos
    match /photos/{photoId} {
      allow read, write: if true;
    }
    
    // Default: Authenticated for all other paths
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
